# Auto-normalize line endings: LF in the repo, native on checkout.
# Existing files keep their current line endings until they're next modified.
* text=auto

# Explicit text file types
*.html      text
*.css       text
*.js        text
*.json      text
*.md        text
*.txt       text
*.xml       text
*.svg       text
*.yml       text
*.yaml      text
.gitignore  text
.gitattributes text

# Binary file types (never normalize)
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
